{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/session-setup.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/check-embargo.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/scripts/detect-jira-ticket.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/check-embargo.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "bash -c 'echo \"[hook] Ensuring pre-commit hooks are installed...\" >&2; if command -v pre-commit &>/dev/null; then pre-commit install --allow-missing-config 2>/dev/null; fi'",
            "if": "Bash(git commit *)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/scripts/enforce-pr-skill.sh",
            "if": "Bash(gh pr create *)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/scripts/coderabbit-review-gate.sh",
            "if": "Bash(gh pr create *)",
            "timeout": 120
          },
          {
            "type": "command",
            "command": ".claude/scripts/validate-commit-msg.sh",
            "if": "Bash(git commit *)",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'INPUT=$(cat); RESPONSE=$(echo \"$INPUT\" | jq -r \".tool_response.stdout // empty\"); PR_URL=$(echo \"$RESPONSE\" | grep -oP \"https://github.com/quay/quay/pull/\\d+\" | head -1 || true); if [ -n \"$PR_URL\" ]; then PR_NUM=$(echo \"$PR_URL\" | grep -oP \"\\d+$\"); jq -n --arg pr \"$PR_NUM\" \"{hookSpecificOutput:{hookEventName:\\\"PostToolUse\\\",additionalContext:(\\\"PR #\\\" + \\$pr + \\\" created. You MUST now run /poll \\\" + \\$pr + \\\" immediately.\\\")}}\"; fi'",
            "if": "Bash(gh pr create *)",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/scripts/check-target-version.sh",
            "if": "Bash(git push *)",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash -c 'PR_NUM=$(gh pr view --json number,state -q \"select(.state==\\\"OPEN\\\") | .number\" 2>/dev/null || true); if [ -n \"$PR_NUM\" ]; then jq -n --arg pr \"$PR_NUM\" \"{hookSpecificOutput:{hookEventName:\\\"PostToolUse\\\",additionalContext:(\\\"Push detected for open PR #\\\" + \\$pr + \\\". You MUST now run /poll \\\" + \\$pr + \\\" immediately. Do NOT continue other work until poll is running.\\\")}}\"; fi'",
            "if": "Bash(git push *)",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/save-session-state.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/scripts/workflow-next-step.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
